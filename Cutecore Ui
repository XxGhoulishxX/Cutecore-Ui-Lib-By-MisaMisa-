    gradientFrame.BackgroundTransparency = 0.6
    gradientFrame.Parent = self.Main
    local gradient = CreateGradient(Theme.GradientStart, Theme.GradientMid, Theme.GradientEnd)
    gradient.Parent = gradientFrame
    
    -- ========== LUNA-STYLE HEADER ==========
