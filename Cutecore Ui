    self.Title.Position = UDim2.new(0, 15, 0, 15)
    self.Title.BackgroundTransparency = 1
    self.Title.Text = "🌸 Cutecore UI 🌸"
    self.Title.TextColor3 = Theme.Text
    self.Title.TextSize = 18
    self.Title.TextXAlignment = Enum.TextXAlignment.Left
    self.Title.Font = Enum.Font.GothamSemibold
    self.Title.Parent = self.Header
    
    -- Subtitle (like Luna's "by Nebula Softworks")
    self.Subtitle = Instance.new("TextLabel")
    self.Subtitle.Size = UDim2.new(1, -60, 0, 20)
    self.Subtitle.Position = UDim2.new(0, 15, 0, 40)
    self.Subtitle.BackgroundTransparency = 1
    self.Subtitle.Text = "mobile • pink • smooth"
    self.Subtitle.TextColor3 = Theme.TextDim
    self.Subtitle.TextSize = 11
    self.Subtitle.TextXAlignment = Enum.TextXAlignment.Left
    self.Subtitle.Font = Enum.Font.Gotham
    self.Subtitle.Parent = self.Header
    
    -- Close button (bigger for mobile)
    self.CloseBtn = Instance.new("TextButton")
    self.CloseBtn.Size = UDim2.new(0, 40, 0, 40)
    self.CloseBtn.Position = UDim2.new(1, -50, 0, 15)
    self.CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 100)
    self.CloseBtn.BackgroundTransparency = 0.7
    self.CloseBtn.Text = "✕"
    self.CloseBtn.TextColor3 = Theme.Text
    self.CloseBtn.TextSize = 20
    self.CloseBtn.Font = Enum.Font.GothamBold
    self.CloseBtn.BorderSizePixel = 0
    self.CloseBtn.Parent = self.Header
    
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 12)
    closeCorner.Parent = self.CloseBtn
    
    self.CloseBtn.MouseButton1Click:Connect(function()
        PlayClickSound()
        self.Gui:Destroy()
    end)
    
    -- ========== DRAG HANDLE (mobile friendly) ==========
    self.DragHandle = Instance.new("Frame")
    self.DragHandle.Size = UDim2.new(1, -100, 0, 50)
    self.DragHandle.Position = UDim2.new(0, 0, 0, 0)
    self.DragHandle.BackgroundTransparency = 1
    self.DragHandle.Parent = self.Header
    
    local dragging = false
    local dragStart, startPos
    
    self.DragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = self.Main.Position
        end
    end)
    
    self.DragHandle.InputEnded:Connect(function(input)
        dragging = false
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            self.Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    -- ========== TAB SYSTEM ==========
    self.TabBar = Instance.new("Frame")
    self.TabBar.Size = UDim2.new(1, 0, 0, 45)
    self.TabBar.Position = UDim2.new(0, 0, 0, 70)
    self.TabBar.BackgroundColor3 = Theme.Surface
    self.TabBar.BackgroundTransparency = 0.5
    self.TabBar.Parent = self.Main
    
    local tabCorner = Instance.new("UICorner")
    tabCorner.CornerRadius = UDim.new(0, 0)
    tabCorner.Parent = self.TabBar
    
    -- Tab buttons container
    self.TabButtons = Instance.new("Frame")
    self.TabButtons.Size = UDim2.new(1, 0, 1, 0)
    self.TabButtons.BackgroundTransparency = 1
    self.TabButtons.Parent = self.TabBar
    
    -- Content container
    self.Content = Instance.new("Frame")
    self.Content.Size = UDim2.new(1, -10, 1, -125)
    self.Content.Position = UDim2.new(0, 5, 0, 120)
    self.Content.BackgroundTransparency = 1
    self.Content.Parent = self.Main
    
    -- Scrollable frame for content
    self.Scroll = Instance.new("ScrollingFrame")
    self.Scroll.Size = UDim2.new(1, 0, 1, 0)
    self.Scroll.BackgroundTransparency = 1
    self.Scroll.BorderSizePixel = 0
    self.Scroll.ScrollBarThickness = 4
    self.Scroll.ScrollBarImageColor3 = Theme.Accent
    self.Scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    self.Scroll.Parent = self.Content
    
    self.ScrollLayout = Instance.new("UIListLayout")
    self.ScrollLayout.Padding = UDim.new(0, 10)
    self.ScrollLayout.SortOrder = Enum.SortOrder.LayoutOrder
    self.ScrollLayout.Parent = self.Scroll
    
    self.ScrollLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        self.Scroll.CanvasSize = UDim2.new(0, 0, 0, self.ScrollLayout.AbsoluteContentSize.Y + 20)
    end)
    
    self.Tabs = {}
    self.CurrentTab = nil
    
    return self
end

-- ================================
-- CREATE TAB (Mobile friendly)
-- ================================
function Window:CreateTab(name, icon)
    PlayClickSound()
    
    local btnWidth = 80
    local btnX = (#self.Tabs) * btnWidth
    
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(0, btnWidth, 1, -5)
    tabBtn.Position = UDim2.new(0, btnX, 0, 2)
    tabBtn.BackgroundColor3 = Theme.Surface
    tabBtn.BackgroundTransparency = 0.8
    tabBtn.Text = (icon or "🌸") .. " " .. name
    tabBtn.TextColor3 = Theme.TextDim
    tabBtn.TextSize = 12
    tabBtn.Font = Enum.Font.GothamMedium
    tabBtn.BorderSizePixel = 0
    tabBtn.Parent = self.TabButtons
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = tabBtn
    
    local tabPage = Instance.new("Frame")
    tabPage.Size = UDim2.new(1, 0, 1, 0)
    tabPage.BackgroundTransparency = 1
    tabPage.Visible = false
    tabPage.Parent = self.Scroll
    
    local tabLayout = Instance.new("UIListLayout")
    tabLayout.Padding = UDim.new(0, 10)
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Parent = tabPage
    
    tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabPage.Size = UDim2.new(1, 0, 0, tabLayout.AbsoluteContentSize.Y)
        self.Scroll.CanvasSize = UDim2.new(0, 0, 0, self.ScrollLayout.AbsoluteContentSize.Y)
    end)
    
    local tab = {Button = tabBtn, Page = tabPage, Name = name, Layout = tabLayout}
    table.insert(self.Tabs, tab)
    
    tabBtn.MouseButton1Click:Connect(function()
        PlayClickSound()
        for _, t in pairs(self.Tabs) do
            t.Page.Visible = false
            t.Button.BackgroundTransparency = 0.8
            t.Button.TextColor3 = Theme.TextDim
        end
        tabPage.Visible = true
        tabBtn.BackgroundTransparency = 0.3
        tabBtn.TextColor3 = Theme.Accent
        self.CurrentTab = tab
    end)
    
    if not self.CurrentTab then
        tabBtn:Trigger()
    end
    
    return tabPage, tabLayout
end

