-- ================================
-- SERVICES
-- ================================
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Mouse = Player:GetMouse()
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local SoundService = game:GetService("SoundService")

-- ================================
-- MOBILE DETECTION
-- ================================
local isMobile = UserInputService.TouchEnabled
local screenSize = Camera.ViewportSize
local isSmallPhone = screenSize.Y <= 900 -- Vivo Y06 is ~854px tall

-- ================================
-- UTILITIES
-- ================================
local function CreateSound()
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://9120386646"
    sound.Volume = 0.25
    sound.Parent = SoundService
    return sound
end

local function PlayClickSound()
    local sound = CreateSound()
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 1)
end

local function CreateGradient(color1, color2, color3)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, color1),
        ColorSequenceKeypoint.new(0.5, color2),
        ColorSequenceKeypoint.new(1, color3)
    }
    gradient.Rotation = 45
    return gradient
end

-- ================================
-- MOBILE-FRIENDLY THEME
-- ================================
local Theme = {
    -- Gradient (Luna-inspired + pink)
    GradientStart = Color3.fromRGB(255, 182, 193),  -- Pink
    GradientMid = Color3.fromRGB(218, 112, 214),    -- Purple
    GradientEnd = Color3.fromRGB(255, 140, 170),    -- Soft pink
    
    Background = Color3.fromRGB(25, 22, 30),
    Surface = Color3.fromRGB(40, 36, 45),
    Card = Color3.fromRGB(50, 46, 55),
    Text = Color3.fromRGB(255, 245, 250),
    TextDim = Color3.fromRGB(200, 185, 195),
    Accent = Color3.fromRGB(255, 120, 160),
    
    -- Mobile sizes
    WindowSize = isSmallPhone and UDim2.new(0, 340, 0, 500) or UDim2.new(0, 400, 0, 580),
    CornerRadius = UDim.new(0, 16),
    ButtonHeight = 44, -- big enough for fingers
}

-- ================================
-- MAIN WINDOW (Mobile Optimized)
-- ================================
local Window = {}
Window.__index = Window

