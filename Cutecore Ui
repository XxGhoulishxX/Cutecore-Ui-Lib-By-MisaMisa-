function Window:CreateActionButton(parent, icon, text, xOffset, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.3, -5, 1, -5)
    btn.Position = UDim2.new(xOffset or 0, 5, 0, 0)
    btn.BackgroundColor3 = Theme.Accent
    btn.BackgroundTransparency = 0.5
    btn.Text = icon .. " " .. text
    btn.TextColor3 = Theme.Text
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamMedium
    btn.BorderSizePixel = 0
    btn.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = btn
    
    btn.MouseButton1Click:Connect(function()
        PlayClickSound()
        -- Bounce effect
        local originalSize = btn.Size
        TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, originalSize.Y.Scale, originalSize.Y.Offset + 3)
        }):Play()
        task.wait(0.08)
        TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {
            Size = originalSize
        }):Play()
        if callback then callback() end
    end)
    
    return btn
end

