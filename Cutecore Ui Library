    -- Animate open with spring
    tw(win, {Size = UDim2.new(0, W, 0, H)}, 0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    return self
end

function SugarUI:Notify(title, desc, duration, notifType)
