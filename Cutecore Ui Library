-- Create gradient texture
local function createGradient(color1, color2, vertical)
    local gradient = Instance.new("ImageLabel")
    gradient.Size = UDim2.new(1, 0, 1, 0)
    gradient.BackgroundTransparency = 1
    gradient.Image = "rbxassetid://4155982913" -- Soft gradient
    gradient.ImageColor3 = color1
    gradient.ImageTransparency = 0
    if vertical then
        gradient.ImageRectSize = Vector2.new(1, 100)
        gradient.ImageRectOffset = Vector2.new(0, 0)
    end
    return gradient
end

-- Enhanced tween with easing options
local function tw(obj, props, dur, style, dir, delay)
    if delay then task.wait(delay) end
    TweenService:Create(obj,
        TweenInfo.new(dur or 0.22, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props):Play()
end

-- Particle effect creator
local function createParticles(parent, color, count)
    local particleContainer = Instance.new("Frame")
    particleContainer.Size = UDim2.new(1, 0, 1, 0)
    particleContainer.BackgroundTransparency = 1
    particleContainer.Parent = parent
    
    for i = 1, count do
        local particle = Instance.new("Frame")
        particle.Size = UDim2.new(0, math.random(3, 6), 0, math.random(3, 6))
        particle.Position = UDim2.new(math.random(), 0, math.random(), 0)
        particle.BackgroundColor3 = color
        particle.BorderSizePixel = 0
        particle.BackgroundTransparency = 0.6
        particle.Parent = particleContainer
        corner(particle, 3)
        
        -- Animate particle
        local startPos = particle.Position
        tw(particle, {
            Position = UDim2.new(startPos.X.Scale + (math.random(-50, 50)/100), 0, 
                                 startPos.Y.Scale + (math.random(-30, 30)/100), 0),
            BackgroundTransparency = 1
        }, math.random(1, 3), Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        
        game:GetService("Debris"):AddItem(particle, 2)
    end
    
    game:GetService("Debris"):AddItem(particleContainer, 2)
end

-- Enhanced corner with glow
local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 12)
    c.Parent = p
    return c
end

-- Glow effect
local function addGlow(frame, color, size, transparency)
    local glow = Instance.new("ImageLabel")
    glow.Size = UDim2.new(1, size or 20, 1, size or 20)
    glow.Position = UDim2.new(0.5, -(size or 20)/2, 0.5, -(size or 20)/2)
    glow.AnchorPoint = Vector2.new(0.5, 0.5)
    glow.BackgroundTransparency = 1
    glow.Image = "rbxassetid://6014261993"
    glow.ImageColor3 = color or T.GlowColor
    glow.ImageTransparency = transparency or 0.5
    glow.ScaleType = Enum.ScaleType.Slice
    glow.SliceCenter = Rect.new(49, 49, 450, 450)
    glow.ZIndex = frame.ZIndex - 1
    glow.Parent = frame
    return glow
end

local function stroke(p, color, thick)
    local s = Instance.new("UIStroke")
    s.Color     = color or T.CardBorder
    s.Thickness = thick or 1.5
    s.Parent    = p
    return s
end

-- Enhanced click sound with pitch variation
local function playClick()
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://6042053626"
    s.Volume  = 0.3
    s.PlaybackSpeed = 0.9 + math.random() * 0.2
    s.Parent  = SoundService
    s:Play()
    game:GetService("Debris"):AddItem(s, 1)
end

-- Enhanced hover with scale
local function addHover(btn, normal, hover)
    btn.MouseEnter:Connect(function()
        tw(btn, {BackgroundColor3 = hover}, 0.14)
        tw(btn, {Size = UDim2.new(btn.Size.X.Scale, btn.Size.X.Offset, 
                                   btn.Size.Y.Scale, btn.Size.Y.Offset + 2)}, 0.1)
    end)
    btn.MouseLeave:Connect(function()
        tw(btn, {BackgroundColor3 = normal}, 0.14)
        tw(btn, {Size = UDim2.new(btn.Size.X.Scale, btn.Size.X.Offset, 
                                   btn.Size.Y.Scale, btn.Size.Y.Offset - 2)}, 0.1)
    end)
    btn.MouseButton1Down:Connect(function()
        tw(btn, {BackgroundTransparency = 0.2, Size = UDim2.new(btn.Size.X.Scale, btn.Size.X.Offset, 
                                                                btn.Size.Y.Scale, btn.Size.Y.Offset - 2)}, 0.05)
    end)
    btn.MouseButton1Up:Connect(function()
        tw(btn, {BackgroundTransparency = 0, Size = UDim2.new(btn.Size.X.Scale, btn.Size.X.Offset, 
                                                              btn.Size.Y.Scale, btn.Size.Y.Offset + 2)}, 0.08)
    end)
end

------------------------------------------------------------------------
-- Enhanced Draggable with spring physics
------------------------------------------------------------------------
local function makeDraggable(frame, handle)
    local dragging, dragInput, mousePos, framePos = false, nil, nil, nil
    local springVelocity = 0
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            mousePos  = input.Position
            framePos  = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local d = input.Position - mousePos
            frame.Position = UDim2.new(
                framePos.X.Scale, framePos.X.Offset + d.X,
                framePos.Y.Scale, framePos.Y.Offset + d.Y
            )
        end
    end)
end

