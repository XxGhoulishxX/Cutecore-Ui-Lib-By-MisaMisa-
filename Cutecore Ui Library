    dl.Parent         = card

    -- Close button with hover effect
    local xBtn = Instance.new("TextButton")
    xBtn.Size             = UDim2.new(0, 22, 0, 22)
    xBtn.Position         = UDim2.new(1, -28, 0, 8)
    xBtn.BackgroundTransparency = 1
    xBtn.Text             = "✕"
    xBtn.TextColor3       = T.TextMuted
    xBtn.Font             = Enum.Font.GothamBold
    xBtn.TextSize         = 12
    xBtn.ZIndex           = 53
    xBtn.Parent           = card
    
    xBtn.MouseEnter:Connect(function() 
        tw(xBtn, {TextColor3 = T.Primary}, 0.1)
        tw(xBtn, {TextSize = 14}, 0.1)
    end)
    xBtn.MouseLeave:Connect(function() 
        tw(xBtn, {TextColor3 = T.TextMuted}, 0.1)
        tw(xBtn, {TextSize = 12}, 0.1)
