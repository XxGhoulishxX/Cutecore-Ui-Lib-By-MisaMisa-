        end)
        dropBtn.MouseLeave:Connect(function()
            tw(dropBtn, {BackgroundColor3 = T.InputBg}, 0.1)
        end)

        local list = Instance.new("ScrollingFrame")
        list.Size             = UDim2.new(0.45, 0, 0, math.min(#options, 5) * 32 + 8)
        list.Position         = UDim2.new(0.53, 0, 1, 4)
        list.BackgroundColor3 = T.CardBg
        list.Visible          = false
        list.ZIndex           = 20
        list.Parent           = f
        corner(list, 10)
        stroke(list, T.CardBorder, 1)
        list.CanvasSize = UDim2.new(0, 0, 0, #options * 32)
        list.ScrollBarThickness = 3

        local ll = Instance.new("UIListLayout")
        ll.SortOrder = Enum.SortOrder.LayoutOrder
        ll.Padding   = UDim.new(0, 2)
        ll.Parent    = list

        local lp = Instance.new("UIPadding")
        lp.PaddingTop   = UDim.new(0, 4)
        lp.PaddingLeft  = UDim.new(0, 4)
        lp.PaddingRight = UDim.new(0, 4)
        lp.Parent       = list

        for _, opt in ipairs(options) do
            local ob = Instance.new("TextButton")
            ob.Size             = UDim2.new(1, 0, 0, 28)
            ob.BackgroundColor3 = T.CardBg
            ob.Text             = opt
            ob.TextColor3       = T.TextDark
            ob.Font             = Enum.Font.Gotham
            ob.TextSize         = 12
            ob.ZIndex           = 21
            ob.Parent           = list
            corner(ob, 6)
            
            ob.MouseEnter:Connect(function() 
                tw(ob, {BackgroundColor3 = T.InputBg}, 0.1)
                tw(ob, {TextColor3 = T.Primary}, 0.1)
            end)
            ob.MouseLeave:Connect(function() 
                tw(ob, {BackgroundColor3 = T.CardBg}, 0.1)
                tw(ob, {TextColor3 = T.TextDark}, 0.1)
            end)
            
            ob.MouseButton1Click:Connect(function()
                playClick()
                selected     = opt
                dropBtn.Text = opt .. "  ▼"
                list.Visible = false
                open         = false
                if callback then callback(opt) end
            end)
        end

        dropBtn.MouseButton1Click:Connect(function()
            playClick()
            open = not open
            list.Visible = open
            if open then
                tw(list, {BackgroundTransparency = 0}, 0.2)
            else
                tw(list, {BackgroundTransparency = 1}, 0.2)
                task.delay(0.2, function() list.Visible = false end)
            end
        end)

        return self
    end

    return tab
