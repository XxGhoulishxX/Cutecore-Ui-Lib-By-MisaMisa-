    local function card(h)
        local f = Instance.new("Frame")
        f.Size             = UDim2.new(1, 0, 0, h)
        f.BackgroundColor3 = T.CardBg
        f.BorderSizePixel  = 0
        f.ZIndex           = 5
        f.Parent           = scroll
        corner(f, 14)
        stroke(f, T.CardBorder, 1.2)
        
        -- Add subtle shadow on hover
        local cardGlow = addGlow(f, T.Primary, 25, 0.2)
        cardGlow.Visible = false
        
        f.MouseEnter:Connect(function()
            tw(cardGlow, {ImageTransparency = 0.1}, 0.2)
            cardGlow.Visible = true
            tw(f, {Position = UDim2.new(0, 0, 0, -2)}, 0.2)
        end)
        f.MouseLeave:Connect(function()
            tw(cardGlow, {ImageTransparency = 0.2}, 0.2)
            task.delay(0.2, function() if f and f.Parent then cardGlow.Visible = false end end)
            tw(f, {Position = UDim2.new(0, 0, 0, 0)}, 0.2)
        end)
        
        return f
    end

