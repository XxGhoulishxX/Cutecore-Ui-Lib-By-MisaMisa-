        lbl.Font             = Enum.Font.Gotham
        lbl.TextSize         = 12
        lbl.TextXAlignment   = Enum.TextXAlignment.Left
        lbl.ZIndex           = 6
        lbl.Parent           = f

        local box = Instance.new("TextBox")
        box.Size             = UDim2.new(1, -32, 0, 34)
        box.Position         = UDim2.new(0, 16, 0, 32)
        box.BackgroundColor3 = T.InputBg
        box.PlaceholderText  = placeholder or "Type here..."
        box.PlaceholderColor3 = T.TextMuted
        box.Text             = ""
        box.TextColor3       = T.TextDark
        box.Font             = Enum.Font.Gotham
        box.TextSize         = 13
        box.TextXAlignment   = Enum.TextXAlignment.Left
        box.ClearTextOnFocus = false
        box.ZIndex           = 6
        box.Parent           = f
        corner(box, 10)

        local bp = Instance.new("UIPadding")
        bp.PaddingLeft = UDim.new(0, 12)
        bp.Parent      = box
        
        if maxLength then
            local counter = Instance.new("TextLabel")
            counter.Size = UDim2.new(0.3, 0, 0, 16)
            counter.Position = UDim2.new(0.7, 0, 1, -20)
            counter.BackgroundTransparency = 1
            counter.Text = "0/" .. maxLength
            counter.TextColor3 = T.TextMuted
            counter.Font = Enum.Font.Gotham
            counter.TextSize = 10
            counter.TextXAlignment = Enum.TextXAlignment.Right
            counter.Parent = f
            
            box.Changed:Connect(function()
                if #box.Text > maxLength then
                    box.Text = box.Text:sub(1, maxLength)
                end
                counter.Text = #box.Text .. "/" .. maxLength
            end)
        end

        box.Focused:Connect(function()
            tw(f, {BackgroundColor3 = Color3.fromRGB(255, 240, 248)}, 0.15)
            tw(box, {BackgroundColor3 = Color3.fromRGB(255, 245, 250)}, 0.15)
        end)
        
        box.FocusLost:Connect(function(enter)
            tw(f, {BackgroundColor3 = T.CardBg}, 0.15)
            tw(box, {BackgroundColor3 = T.InputBg}, 0.15)
            if callback then callback(box.Text, enter) end
        end)

        return self
    end

    -- Enhanced Dropdown with search
    function tab:AddDropdown(label, options, callback)
        local selected = options[1] or "Select..."
