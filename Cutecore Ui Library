    -- Slide in with bounce
    tw(card, {Position = UDim2.new(0, 0, 0, 0)}, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    local function dismiss()
        tw(card, {Position = UDim2.new(1.1, 0, 0, 0), BackgroundTransparency = 0.4}, 0.3)
        tw(card, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
        task.delay(0.35, function() if card and card.Parent then card:Destroy() end end)
    end

    xBtn.MouseButton1Click:Connect(function()
        playClick()
        dismiss()
    end)
    
    task.delay(duration, function()
        if card and card.Parent then dismiss() end
    end)
