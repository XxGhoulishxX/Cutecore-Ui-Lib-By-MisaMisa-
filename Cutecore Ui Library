function SugarUI:AddTab(tabName, icon)
    icon = icon or "•"

    -- ScrollingFrame with smooth scrolling
    local scroll = Instance.new("ScrollingFrame")
    scroll.Name                = "Tab_"..tabName
    scroll.Size                = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel     = 0
    scroll.ScrollBarThickness  = 4
    scroll.ScrollBarImageColor3 = T.Primary
    scroll.ScrollBarImageTransparency = 0.5
    scroll.CanvasSize          = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.Visible             = false
    scroll.ZIndex              = 4
    scroll.Parent              = self._content
    corner(scroll, 16)

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding   = UDim.new(0, 10)
    layout.Parent    = scroll

    local pad = Instance.new("UIPadding")
    pad.PaddingTop    = UDim.new(0, 16)
    pad.PaddingLeft   = UDim.new(0, 16)
    pad.PaddingRight  = UDim.new(0, 16)
    pad.PaddingBottom = UDim.new(0, 16)
    pad.Parent        = scroll

    -- Enhanced sidebar tab button
    local tabBtn = Instance.new("TextButton")
    tabBtn.Name             = "TB_"..tabName
    tabBtn.Size             = UDim2.new(1, 0, 0, 42)
    tabBtn.BackgroundColor3 = T.Sidebar
    tabBtn.Text             = icon.."  "..tabName
    tabBtn.TextColor3       = T.TextMuted
    tabBtn.Font             = Enum.Font.Gotham
    tabBtn.TextSize         = 13
    tabBtn.TextXAlignment   = Enum.TextXAlignment.Left
    tabBtn.LayoutOrder      = #self._tabs + 1
    tabBtn.ZIndex           = 5
    tabBtn.Parent           = self._sidebar
    corner(tabBtn, 12)
    
    -- Add hover glow
    local tabGlow = addGlow(tabBtn, T.Primary, 30, 0.4)
    tabGlow.Visible = false

    local tbPad = Instance.new("UIPadding")
    tbPad.PaddingLeft = UDim.new(0, 12)
    tbPad.Parent      = tabBtn

    table.insert(self._tabs, {name = tabName, scroll = scroll, btn = tabBtn})

    local function activate()
        playClick()
        for _, t in ipairs(self._tabs) do
            t.scroll.Visible = false
            tw(t.btn, {BackgroundColor3 = T.Sidebar, TextColor3 = T.TextMuted}, 0.18)
            t.btn.Font = Enum.Font.Gotham
            if t.btn:FindFirstChild("Glow") then t.btn.Glow.Visible = false end
        end
        scroll.Visible = true
        tw(tabBtn, {BackgroundColor3 = T.SidebarActive, TextColor3 = T.White}, 0.22)
        tabBtn.Font    = Enum.Font.GothamBold
        if tabGlow then tabGlow.Visible = true end
        self._activeTab = tabName
    end

    tabBtn.MouseButton1Click:Connect(activate)
    tabBtn.MouseEnter:Connect(function()
        if self._activeTab ~= tabName then
            tw(tabBtn, {BackgroundColor3 = T.SidebarHover}, 0.14)
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if self._activeTab ~= tabName then
            tw(tabBtn, {BackgroundColor3 = T.Sidebar}, 0.14)
        end
    end)

    if #self._tabs == 1 then activate() end

    -- Tab element builder with enhanced visuals
    local tab = {}
