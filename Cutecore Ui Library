    -- Enhanced Toggle with smoother animation
    function tab:AddToggle(label, default, callback)
        local toggled = default or false
        local f = card(48)

        local lbl = Instance.new("TextLabel")
        lbl.Size             = UDim2.new(1, -80, 1, 0)
        lbl.Position         = UDim2.new(0, 16, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text             = label
        lbl.TextColor3       = T.TextDark
        lbl.Font             = Enum.Font.Gotham
        lbl.TextSize         = 13
        lbl.TextXAlignment   = Enum.TextXAlignment.Left
        lbl.ZIndex           = 6
        lbl.Parent           = f

        local track = Instance.new("Frame")
        track.Size             = UDim2.new(0, 50, 0, 26)
        track.Position         = UDim2.new(1, -66, 0.5, -13)
        track.BackgroundColor3 = toggled and T.ToggleOn or T.ToggleOff
        track.ZIndex           = 6
        track.Parent           = f
        corner(track, 13)

        local thumb = Instance.new("Frame")
        thumb.Size             = UDim2.new(0, 20, 0, 20)
        thumb.Position         = toggled and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 4, 0.5, -10)
        thumb.BackgroundColor3 = T.White
        thumb.ZIndex           = 7
        thumb.Parent           = track
        corner(thumb, 10)

        local function doToggle()
            playClick()
            toggled = not toggled
            tw(track, {BackgroundColor3 = toggled and T.ToggleOn or T.ToggleOff}, 0.25, Enum.EasingStyle.Quad)
            tw(thumb, {Position = toggled and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 4, 0.5, -10)}, 0.3, Enum.EasingStyle.Elastic)
            if callback then callback(toggled) end
        end

        local hit = Instance.new("TextButton")
        hit.Size             = UDim2.new(1, 0, 1, 0)
        hit.BackgroundTransparency = 1
        hit.Text             = ""
        hit.ZIndex           = 8
        hit.Parent           = f
        hit.MouseButton1Click:Connect(doToggle)

        return self
    end

    -- Enhanced Slider with live value display
    function tab:AddSlider(label, min, max, default, callback)
        min     = min or 0
        max     = max or 100
        default = math.clamp(default or min, min, max)
        local value = default
        local f = card(68)

        local lbl = Instance.new("TextLabel")
        lbl.Size             = UDim2.new(0.7, 0, 0, 24)
        lbl.Position         = UDim2.new(0, 16, 0, 8)
        lbl.BackgroundTransparency = 1
        lbl.Text             = label
        lbl.TextColor3       = T.TextDark
        lbl.Font             = Enum.Font.Gotham
        lbl.TextSize         = 13
        lbl.TextXAlignment   = Enum.TextXAlignment.Left
        lbl.ZIndex           = 6
        lbl.Parent           = f

        local valLbl = Instance.new("TextLabel")
        valLbl.Size             = UDim2.new(0.3, -16, 0, 24)
        valLbl.Position         = UDim2.new(0.7, 0, 0, 8)
        valLbl.BackgroundTransparency = 1
        valLbl.Text             = tostring(value)
        valLbl.TextColor3       = T.Primary
        valLbl.Font             = Enum.Font.GothamBold
        valLbl.TextSize         = 14
        valLbl.TextXAlignment   = Enum.TextXAlignment.Right
        valLbl.ZIndex           = 6
        valLbl.Parent           = f

        local track = Instance.new("Frame")
        track.Size             = UDim2.new(1, -32, 0, 8)
        track.Position         = UDim2.new(0, 16, 0, 46)
        track.BackgroundColor3 = T.SliderBar
        track.ZIndex           = 6
        track.Parent           = f
        corner(track, 4)

        local pct  = (value - min) / (max - min)

        local fill = Instance.new("Frame")
        fill.Size             = UDim2.new(pct, 0, 1, 0)
        fill.BackgroundColor3 = T.SliderFill
        fill.BorderSizePixel  = 0
        fill.ZIndex           = 7
        fill.Parent           = track
        corner(fill, 4)

        local thumb = Instance.new("Frame")
        thumb.Size             = UDim2.new(0, 20, 0, 20)
        thumb.Position         = UDim2.new(pct, -10, 0.5, -10)
        thumb.BackgroundColor3 = T.SliderFill
        thumb.ZIndex           = 8
        thumb.Parent           = track
        corner(thumb, 10)
        stroke(thumb, T.White, 2.5)

        local hit = Instance.new("TextButton")
        hit.Size             = UDim2.new(1, 0, 0, 32)
        hit.Position         = UDim2.new(0, 0, 0.5, -16)
        hit.BackgroundTransparency = 1
        hit.Text             = ""
        hit.ZIndex           = 9
        hit.Parent           = track

        local sliding = false

        local function update(screenX)
            local rel = math.clamp((screenX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            value = math.floor(min + rel * (max - min) + 0.5)
            valLbl.Text = tostring(value)
            fill.Size   = UDim2.new(rel, 0, 1, 0)
            thumb.Position = UDim2.new(rel, -10, 0.5, -10)
        end

        hit.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                sliding = true
                update(i.Position.X)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(i)
            if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch) then
                update(i.Position.X)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(i)
            if sliding and (i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch) then
                sliding = false
                playClick()
                if callback then callback(value) end
            end
        end)

        return self
    end

    -- Enhanced Input with character counter
    function tab:AddInput(label, placeholder, callback, maxLength)
        local f = card(74)

        local lbl = Instance.new("TextLabel")
        lbl.Size             = UDim2.new(1, -32, 0, 22)
        lbl.Position         = UDim2.new(0, 16, 0, 8)
