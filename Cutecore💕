local statsSection, statsLayout = window:CreateSection(miscLayout, "Statistics", "📊")
local function AddStat(parent, label, value)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 30)
    frame.BackgroundTransparency = 1
    frame.Parent = parent
    local labelL = Instance.new("TextLabel")
    labelL.Size = UDim2.new(0.6, 0, 1, 0)
    labelL.BackgroundTransparency = 1
    labelL.Text = label
    labelL.TextColor3 = Theme.TextDim
    labelL.TextSize = 13
    labelL.TextXAlignment = Enum.TextXAlignment.Left
    labelL.Font = Enum.Font.Gotham
    labelL.Parent = frame
    local valueL = Instance.new("TextLabel")
    valueL.Size = UDim2.new(0.4, 0, 1, 0)
    valueL.Position = UDim2.new(0.6, 0, 0, 0)
    valueL.BackgroundTransparency = 1
    valueL.Text = value
    valueL.TextColor3 = Theme.Accent
    valueL.TextSize = 13
    valueL.TextXAlignment = Enum.TextXAlignment.Right
    valueL.Font = Enum.Font.GothamBold
    valueL.Parent = frame
    return frame
end
